cache=/Users/jesper/.npm
prefix=~/.npm-global

# --- SECURITY DEFAULTS ---
# Disable malicious script execution (The Worm-Stopper)
ignore-scripts=true

# Pin versions exactly to prevent unexpected "Spice" updates
save-exact=true

# Force security audits on every install
audit=true

# --- HYGIENE ---
# Remove "please fund me" noise
fund=false
# Reduce log noise to see actual security warnings
loglevel=warn
