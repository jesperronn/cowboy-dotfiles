#!/usr/bin/env bash
# shellcheck shell=bash

set -euo pipefail

ROOT=$(cd "$(dirname "$0")/.." && pwd)
status=0
COLOR_ENABLED=1

C_BOLD=$'\033[1m'
C_AQUA=$'\033[36m'
C_0=$'\033[0m'

runner_header() {
  if (( COLOR_ENABLED )); then
    printf '%s%srunning ==> %s%s\n' "$C_BOLD" "$C_AQUA" "${1#$ROOT/}" "$C_0"
  else
    printf 'running ==> %s\n' "${1#$ROOT/}"
  fi
}

while IFS= read -r test_file; do
  [[ -n "$test_file" ]] || continue
  runner_header "$test_file"
  bash "$test_file" || status=$?
done < <(find "$ROOT" -type f -name '*.test.sh' | sort)

exit "$status"
