#!/usr/bin/env bash
# shellcheck shell=bash

set -euo pipefail

PGIT_COLOR_ENABLED=0
PGIT_VERBOSE=0
PGIT_SHOW_HELP=0
PGIT_MODE="run"
PGIT_PARALLEL_TMP_DIR=""

PGIT_DIRS=()
PGIT_GIT_ARGS=()
PGIT_REPO_DIRS=()
PGIT_NO_OUTPUT_DIRS=()
PGIT_FAILED_REPOS=()

PGIT_C_RESET=$'\033[0m'
PGIT_C_DIM=$'\033[2m'
PGIT_C_BOLD=$'\033[1m'
PGIT_C_RED=$'\033[31m'
PGIT_C_GREEN=$'\033[32m'
PGIT_C_SECTION=$'\033[33m'
PGIT_C_ACCENT=$'\033[35m'
PGIT_C_PLACEHOLDER=$'\033[95m'

pgit_reset_state() {
  PGIT_COLOR_ENABLED=0
  PGIT_VERBOSE=0
  PGIT_SHOW_HELP=0
  PGIT_MODE="run"
  PGIT_PARALLEL_TMP_DIR=""

  PGIT_DIRS=()
  PGIT_GIT_ARGS=()
  PGIT_REPO_DIRS=()
  PGIT_NO_OUTPUT_DIRS=()
  PGIT_FAILED_REPOS=()
}

pgit_usage() {
  local section_style="" tool_style="" command_style="" placeholder_style="" flag_style="" reset_style=""

  if (( PGIT_COLOR_ENABLED )); then
    section_style="${PGIT_C_BOLD}${PGIT_C_SECTION}"
    tool_style="${PGIT_C_BOLD}${PGIT_C_ACCENT}"
    command_style="$PGIT_C_GREEN"
    placeholder_style="$PGIT_C_PLACEHOLDER"
    flag_style="$PGIT_C_GREEN"
    reset_style="$PGIT_C_RESET"
  fi

  printf 'Run one git command across multiple repositories.\n\n'
  printf '%sUsage:%s %spgit%s %s[dirs --]%s %s<git-command>%s %s[git-args...]%s\n\n' \
    "$section_style" "$reset_style" \
    "$tool_style" "$reset_style" \
    "$placeholder_style" "$reset_style" \
    "$command_style" "$reset_style" \
    "$placeholder_style" "$reset_style"
  printf '%sExamples:%s\n' "$section_style" "$reset_style"
  printf '  %sfetch%s\n' "$command_style" "$reset_style"
  printf '  %sbranch%s --show-current\n' "$command_style" "$reset_style"
  printf '  %srepo-a repo-b%s -- %sstatus%s -sb\n\n' \
    "$placeholder_style" "$reset_style" "$command_style" "$reset_style"
  printf '%sOptions:%s\n' "$section_style" "$reset_style"
  printf '  %s-h, --help%s  Show this help.\n\n' "$flag_style" "$reset_style"
  printf '%sNotes:%s\n' "$section_style" "$reset_style"
  printf '  - Without dirs, all immediate subdirectories are considered.\n'
  printf '  - A directory is included only if it is a git repository.\n'
}

pgit_color_print() {
  local color="$1"
  shift

  if (( PGIT_COLOR_ENABLED )); then
    printf '%b%s%b\n' "$color" "$*" "$PGIT_C_RESET"
  else
    printf '%s\n' "$*"
  fi
}

pgit_info() {
  pgit_color_print "${PGIT_C_BOLD}${PGIT_C_ACCENT}" "$*"
}

pgit_success() {
  pgit_color_print "$PGIT_C_GREEN" "$*"
}

pgit_warn() {
  pgit_color_print "$PGIT_C_RED" "Warning: $*" >&2
}

pgit_error() {
  pgit_color_print "$PGIT_C_RED" "$*" >&2
}

pgit_verbose() {
  if (( PGIT_VERBOSE )); then
    pgit_color_print "$PGIT_C_DIM" "$*"
  fi
}

parse_opts() {
  if [[ "${1-}" == "--pgit-worker" ]]; then
    PGIT_MODE="worker"
    shift || true
    PGIT_DIRS=("${1-}")
    shift || true
    PGIT_GIT_ARGS=("$@")
    return 0
  fi

  if [[ $# -eq 0 ]]; then
    pgit_usage
    return 1
  fi

  case "${1-}" in
    -h|--help)
      PGIT_SHOW_HELP=1
      return 0
      ;;
  esac

  return 0
}

parse_prereqs() {
  if command -v tput >/dev/null 2>&1 && [[ -t 1 ]]; then
    PGIT_COLOR_ENABLED=1
  else
    PGIT_COLOR_ENABLED=0
  fi
}

is_git_repo_dir() {
  local dir="$1"
  git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || git -C "$dir" rev-parse --is-bare-repository >/dev/null 2>&1
}

pgit_plan_inputs() {
  PGIT_DIRS=()
  PGIT_GIT_ARGS=()

  local separator_found=0
  local arg

  for arg in "$@"; do
    if [[ "$arg" == "--" ]]; then
      separator_found=1
      continue
    fi

    if (( separator_found )); then
      PGIT_GIT_ARGS+=("$arg")
    else
      PGIT_DIRS+=("$arg")
    fi
  done

  if (( ! separator_found )); then
    PGIT_DIRS=(*/)
    PGIT_GIT_ARGS=("$@")
  fi
}

pgit_plan_repo_dirs() {
  PGIT_REPO_DIRS=()

  local dir=""
  for dir in "${PGIT_DIRS[@]}"; do
    [[ -d "$dir" ]] || continue
    [[ "$dir" != "/" ]] && dir="${dir%/}"

    if is_git_repo_dir "$dir"; then
      PGIT_REPO_DIRS+=("$dir")
    fi
  done
}

pgit_format_heading() {
  local label="$1"

  if (( PGIT_COLOR_ENABLED )); then
    printf '%b%s%b' "${PGIT_C_BOLD}${PGIT_C_ACCENT}" "$label" "$PGIT_C_RESET"
  else
    printf '%s' "$label"
  fi
}

pgit_report_no_repos() {
  pgit_error "No git repositories found in selected directories."
}

pgit_report_no_output() {
  if [[ ${#PGIT_NO_OUTPUT_DIRS[@]} -eq 0 ]]; then
    return 0
  fi

  printf '%s\n' "$(pgit_format_heading "no output from")"
  printf '%s\n' "${PGIT_NO_OUTPUT_DIRS[@]}"
}

pgit_report_errors() {
  local failed_repo=""
  local dir=""
  local exit_code=""

  if [[ ${#PGIT_FAILED_REPOS[@]} -eq 0 ]]; then
    return 0
  fi

  printf '%s\n' "$(pgit_format_heading "errors")"

  for failed_repo in "${PGIT_FAILED_REPOS[@]}"; do
    dir="${failed_repo%%$'\t'*}"
    exit_code="${failed_repo##*$'\t'}"
    printf '%s (exit %s)\n' "$dir" "$exit_code"
  done
}

pgit_worker() {
  local dir="$1"
  local result_file="$2"
  shift 2

  local output=""
  local exit_code=0
  local had_output=0

  output="$(git -C "$dir" "$@" 2>&1)" || exit_code=$?

  if [[ -n "$output" ]]; then
    had_output=1
    printf '%s\n%s\n' "$(pgit_format_heading "$dir")" "$output"
  fi

  printf '%s\n%s\n%s\n' "$exit_code" "$had_output" "$dir" > "$result_file"
  return "$exit_code"
}

pgit_init_parallel_state() {
  PGIT_PARALLEL_TMP_DIR="$(mktemp -d)"
}

pgit_cleanup_parallel_state() {
  if [[ -n "$PGIT_PARALLEL_TMP_DIR" && -d "$PGIT_PARALLEL_TMP_DIR" ]]; then
    rm -rf "$PGIT_PARALLEL_TMP_DIR"
  fi

  PGIT_PARALLEL_TMP_DIR=""
}

pgit_collect_parallel_results() {
  local result_file=""
  local result_lines=()
  local exit_code=""
  local had_output=""
  local dir=""

  PGIT_NO_OUTPUT_DIRS=()
  PGIT_FAILED_REPOS=()

  for result_file in "$@"; do
    [[ -f "$result_file" ]] || continue
    mapfile -t result_lines < "$result_file"

    exit_code="${result_lines[0]:-0}"
    had_output="${result_lines[1]:-0}"
    dir="${result_lines[2]:-}"

    if [[ "$had_output" == "0" ]]; then
      PGIT_NO_OUTPUT_DIRS+=("$dir")
    fi

    if [[ "$exit_code" != "0" ]]; then
      PGIT_FAILED_REPOS+=("${dir}"$'\t'"${exit_code}")
    fi
  done
}

pgit_apply_parallel_runs() {
  local dir=""
  local worker_pid=""
  local output_file=""
  local result_file=""
  local run_status=0
  local worker_pids=()
  local output_files=()
  local result_files=()

  for dir in "${PGIT_REPO_DIRS[@]}"; do
    output_file="$(mktemp "${PGIT_PARALLEL_TMP_DIR}/output.XXXXXX")"
    result_file="$(mktemp "${PGIT_PARALLEL_TMP_DIR}/result.XXXXXX")"

    pgit_worker "$dir" "$result_file" "${PGIT_GIT_ARGS[@]}" > "$output_file" &
    worker_pid="$!"
    worker_pids+=("$worker_pid")
    output_files+=("$output_file")
    result_files+=("$result_file")
  done

  for worker_pid in "${worker_pids[@]}"; do
    if ! wait "$worker_pid"; then
      :
    fi
  done

  for output_file in "${output_files[@]}"; do
    if [[ -s "$output_file" ]]; then
      cat "$output_file"
    fi
  done

  pgit_collect_parallel_results "${result_files[@]}"

  if [[ ${#PGIT_FAILED_REPOS[@]} -gt 0 ]]; then
    run_status="${PGIT_FAILED_REPOS[0]##*$'\t'}"
  fi

  return "$run_status"
}

pgit_apply_repo_commands() {
  local run_status=0

  pgit_init_parallel_state
  pgit_apply_parallel_runs || run_status=$?
  pgit_cleanup_parallel_state

  return "$run_status"
}

run_main() {
  local main_status=0

  pgit_reset_state
  parse_opts "$@" || return $?
  parse_prereqs

  if (( PGIT_SHOW_HELP )); then
    pgit_usage
    return 0
  fi

  if [[ "$PGIT_MODE" == "worker" ]]; then
    pgit_worker "${PGIT_DIRS[0]}" "${PGIT_GIT_ARGS[0]}" "${PGIT_GIT_ARGS[@]:1}"
    return $?
  fi

  pgit_plan_inputs "$@"
  pgit_plan_repo_dirs

  if [[ ${#PGIT_REPO_DIRS[@]} -eq 0 ]]; then
    pgit_report_no_repos
    return 1
  fi

  pgit_apply_repo_commands || main_status=$?
  pgit_report_errors
  pgit_report_no_output

  return "$main_status"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  run_main "$@"
fi
