#!/usr/bin/env bash
#
# Run a git command in multiple repositories.
#
# Usage examples:
#   pgit fetch
#   pgit branch --show-current
#   pgit repo-a repo-b -- status -sb

set -euo pipefail

C_0="\e[0m"
C_BOLD="\e[1m"
C_MAGENTA="\e[35m"

usage() {
  cat <<'HELP'
pgit

Usage:
  pgit [dirs --] <git-command> [git-args...]

Examples:
  pgit fetch
  pgit branch --show-current
  pgit repo-a repo-b -- status -sb

Notes:
  - Without dirs, all immediate subdirectories are considered.
  - A directory is included only if it is a git repository (work tree or bare).
HELP
}

parse_args() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
    return 2
  fi

  if [[ $# -eq 0 ]]; then
    usage
    return 1
  fi
}

is_git_repo_dir() {
  local dir="$1"
  git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || git -C "$dir" rev-parse --is-bare-repository >/dev/null 2>&1
}

pgit_collect_inputs() {
  P_GIT_DIRS=()
  P_GIT_GIT_ARGS=()

  local separator_found=0
  local arg
  for arg in "$@"; do
    if [[ "$arg" == "--" ]]; then
      separator_found=1
      continue
    fi

    if [[ $separator_found -eq 0 ]]; then
      P_GIT_DIRS=("${P_GIT_DIRS[@]}" "$arg")
    else
      P_GIT_GIT_ARGS=("${P_GIT_GIT_ARGS[@]}" "$arg")
    fi
  done

  if [[ $separator_found -eq 0 ]]; then
    P_GIT_DIRS=(*/)
    P_GIT_GIT_ARGS=("$@")
  fi
}

pgit_init_colors() {
  P_GIT_H1=""
  P_GIT_H2=""

  if command -v tput >/dev/null 2>&1 && [[ -t 1 ]]; then
    P_GIT_H1="$(tput setaf 5; tput smul; tput bold)"
    P_GIT_H2="$(tput sgr0)"
  fi
}

pgit_collect_repo_dirs() {
  P_GIT_REPO_DIRS=()

  local d

  for d in "${P_GIT_DIRS[@]}"; do
    [[ -d "$d" ]] || continue
    [[ "$d" != "/" ]] && d="${d%/}"

    if is_git_repo_dir "$d"; then
      P_GIT_REPO_DIRS=("${P_GIT_REPO_DIRS[@]}" "$d")
    fi
  done
}

pgit_init_runtime_state() {
  P_GIT_NO_OUTPUT_DIRS=()
  P_GIT_FAILED_REPOS=()
}

pgit_worker() {
  local dir="$1"
  local result_file="$2"
  shift
  shift

  local output
  local exit_code=0
  local had_output=0

  output="$(git -C "$dir" "$@" 2>&1)" || exit_code=$?

  if [[ -n "$output" ]]; then
    had_output=1
    echo -e "${P_GIT_H1}${dir}${P_GIT_H2}\n${output}"
  fi

  printf '%s\n%s\n%s\n' "$exit_code" "$had_output" "$dir" > "$result_file"

  return $exit_code
}

pgit_init_parallel_state() {
  P_GIT_PARALLEL_TMP_DIR="$(mktemp -d)"
}

pgit_cleanup_parallel_state() {
  if [[ -n "${P_GIT_PARALLEL_TMP_DIR:-}" && -d "${P_GIT_PARALLEL_TMP_DIR}" ]]; then
    rm -rf "${P_GIT_PARALLEL_TMP_DIR}"
  fi
}

pgit_collect_parallel_results() {
  local result_file
  local result_lines=()
  local exit_code
  local had_output
  local dir

  P_GIT_NO_OUTPUT_DIRS=()
  P_GIT_FAILED_REPOS=()

  for result_file in "$@"; do
    [[ -f "$result_file" ]] || continue
    mapfile -t result_lines < "$result_file"

    exit_code="${result_lines[0]:-0}"
    had_output="${result_lines[1]:-0}"
    dir="${result_lines[2]:-}"

    if [[ "$had_output" == "0" ]]; then
      P_GIT_NO_OUTPUT_DIRS=("${P_GIT_NO_OUTPUT_DIRS[@]}" "$dir")
    fi

    if [[ "$exit_code" != "0" ]]; then
      P_GIT_FAILED_REPOS=("${P_GIT_FAILED_REPOS[@]}" "${dir}"$'\t'"${exit_code}")
    fi
  done
}

pgit_run_repos_parallel() {
  local dir
  local worker_pid
  local output_file
  local result_file
  local run_status=0
  local worker_pids=()
  local output_files=()
  local result_files=()

  for dir in "${P_GIT_REPO_DIRS[@]}"; do
    output_file="$(mktemp "${P_GIT_PARALLEL_TMP_DIR}/output.XXXXXX")"
    result_file="$(mktemp "${P_GIT_PARALLEL_TMP_DIR}/result.XXXXXX")"

    pgit_worker "$dir" "$result_file" "${P_GIT_GIT_ARGS[@]}" > "$output_file" &
    worker_pids=("${worker_pids[@]}" "$!")
    output_files=("${output_files[@]}" "$output_file")
    result_files=("${result_files[@]}" "$result_file")
  done

  for worker_pid in "${worker_pids[@]}"; do
    if ! wait "$worker_pid"; then
      :
    fi
  done

  for output_file in "${output_files[@]}"; do
    if [[ -s "$output_file" ]]; then
      cat "$output_file"
    fi
  done

  pgit_collect_parallel_results "${result_files[@]}"

  if [[ ${#P_GIT_FAILED_REPOS[@]} -gt 0 ]]; then
    run_status="${P_GIT_FAILED_REPOS[0]##*$'\t'}"
  fi

  return "$run_status"
}

pgit_run_repos() {
  pgit_init_parallel_state
  local run_status=0
  pgit_run_repos_parallel || run_status=$?
  pgit_cleanup_parallel_state
  return $run_status
}

pgit_report_no_repos() {
  echo -e "${C_BOLD}${C_MAGENTA}No git repositories found in selected directories.${C_0}" >&2
}

pgit_report_no_output() {
  if [[ ${#P_GIT_NO_OUTPUT_DIRS[@]} -gt 0 ]]; then
    echo -e "${P_GIT_H1}no output from${P_GIT_H2}"
    printf '%s\n' "${P_GIT_NO_OUTPUT_DIRS[@]}"
  fi
}

pgit_report_errors() {
  local failed_repo
  local dir
  local exit_code

  if [[ ${#P_GIT_FAILED_REPOS[@]} -eq 0 ]]; then
    return
  fi

  echo -e "${P_GIT_H1}errors${P_GIT_H2}"

  for failed_repo in "${P_GIT_FAILED_REPOS[@]}"; do
    dir="${failed_repo%%$'\t'*}"
    exit_code="${failed_repo##*$'\t'}"
    printf '%s (exit %s)\n' "$dir" "$exit_code"
  done
}

run_main() {
  if [[ "${1:-}" == "--pgit-worker" ]]; then
    shift
    pgit_worker "$@"
    return $?
  fi

  local parse_status=0
  parse_args "$@" || parse_status=$?
  case $parse_status in
    0) ;;
    1) return 1 ;;
    2) return 0 ;;
  esac

  pgit_collect_inputs "$@"
  pgit_init_colors
  pgit_init_runtime_state
  pgit_collect_repo_dirs

  if [[ ${#P_GIT_REPO_DIRS[@]} -eq 0 ]]; then
    pgit_report_no_repos
    return 1
  fi

  local run_status=0
  pgit_run_repos || run_status=$?
  pgit_report_errors
  pgit_report_no_output

  return $run_status
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  run_main "$@"
fi
